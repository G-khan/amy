# PayTR Merchant Credentials
# Get these from your PayTR merchant panel: https://www.paytr.com
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt

# Payment URLs (update with your domain in production)
PAYTR_OK_URL=http://localhost:5173/#payment-success
PAYTR_FAIL_URL=http://localhost:5173/#payment-fail

# Test mode: 1 = sandbox, 0 = production
PAYTR_TEST_MODE=1

# Server port
PORT=3001
